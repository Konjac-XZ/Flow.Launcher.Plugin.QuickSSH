<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Plugin meta -->
    <system:String x:Key="plugin_quickssh_plugin_name">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_plugin_description">Rýchlo ukladajte a spúšťajte SSH/SCP pripojenia z Flow Launcher.</system:String>

    <!-- Health / status messages -->
    <system:String x:Key="plugin_quickssh_sshnotinstalled_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_sshnotinstalled_subtitle">Klient OpenSSH nebol nájdený v tomto systéme.</system:String>

    <system:String x:Key="plugin_quickssh_databasenotcreated_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_databasenotcreated_subtitle">Databázu profilov sa nepodarilo vytvoriť.</system:String>

    <!-- Shared / common -->
    <system:String x:Key="plugin_quickssh_noprofiles">Žiadne profily neboli uložené.</system:String>
    <system:String x:Key="plugin_quickssh_noshells">Žiadne shell profily neboli uložené.</system:String>
    <system:String x:Key="plugin_quickssh_save_label">Uložiť:</system:String>
    <system:String x:Key="plugin_quickssh_connect_label">Pripojiť:</system:String>
    <system:String x:Key="plugin_quickssh_addshell_label">Pridať shell:</system:String>

    <!-- PROFILES (list / connect) -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles">Uložené profily</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles">profiles add &lt;name&gt; &lt;ssh-command&gt;  |  remove [filter]  |  rename &lt;old&gt; &lt;new&gt;  |  copy [filter]  |  export  |  import [filter]</system:String>

    <!-- PROFILES ADD -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_add">Pridať profil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_add">Použitie: profiles add &lt;názov&gt; &lt;ssh-príkaz&gt;</system:String>

    <!-- PROFILES REMOVE -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_remove">Odstrániť profil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_remove">Použitie: profiles remove [filter]</system:String>

    <!-- PROFILES RENAME -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_rename">Premenovať profil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_rename">Použitie: profiles rename &lt;starý názov&gt; &lt;nový názov&gt;</system:String>
    <system:String x:Key="plugin_quickssh_rename_notfound">Profil sa nenašiel.</system:String>

    <!-- PROFILES COPY -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_copy">Kopírovať SSH príkaz</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy">Kopírovať:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy_usage">Použitie: profiles copy [filter]</system:String>
    <system:String x:Key="plugin_quickssh_copy_clipboard_error">Nepodarilo sa skopírovať do schránky. Uistite sa, že Flow Launcher beží na UI vlákne.</system:String>

    <!-- PROFILES EXPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_export">Exportovať profily</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export">Exportovať profily do: {0}</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export_usage">Použitie: profiles export</system:String>
    <system:String x:Key="plugin_quickssh_export_success">Exportovaných {0} profil(ov) do {1}</system:String>

    <!-- PROFILES IMPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_import">Importovať profily</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_import_usage">Použitie: profiles import [filter]</system:String>
    <system:String x:Key="plugin_quickssh_import_nofiles">Žiadne súbory .sshconfig alebo .json nenájdené v: {0}</system:String>
    <system:String x:Key="plugin_quickssh_import_success">Importovaných {0} profil(ov) úspešne.</system:String>
    <system:String x:Key="plugin_quickssh_import_empty">V zvolenom súbore sa nenašli žiadne profily.</system:String>

    <!-- DIRECT CONNECT -->
    <system:String x:Key="plugin_quickssh_title_commanddirect">Priame pripojenie</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect">Priame pripojenie:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect_usage">Použitie: ssh root@host  |  ssh -p 22 root@host  |  ssh -i "key" root@host</system:String>

    <!-- SHELL -->
    <system:String x:Key="plugin_quickssh_title_commandshell">Správa shellov</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_add">Pridať shell profil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_add_usage">Použitie: shell add &lt;exe&gt; alebo shell add &lt;názov&gt; &lt;exe + argumenty&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_remove">Odstrániť shell profil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_remove">Použitie: shell remove [filter]</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_help">Použitie: shell add ; remove</system:String>
    <system:String x:Key="plugin_quickssh_shell_selected">(vybraný)</system:String>

    <!-- CONFIG -->
    <system:String x:Key="plugin_quickssh_title_commandconfig">Importovať SSH config</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig">Importovať hosty zo súboru ~/.ssh/config.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig_usage">Použitie: config  (importuje z ~/.ssh/config)</system:String>
    <system:String x:Key="plugin_quickssh_config_imported">Importovaných {0} host(ov) zo SSH config.</system:String>
    <system:String x:Key="plugin_quickssh_config_notfound">Súbor SSH config nebol nájdený na ~/.ssh/config.</system:String>

    <!-- HELP -->
    <system:String x:Key="plugin_quickssh_title_commandhelp">Pomoc</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp">Otvoriť dokumentáciu pluginu na GitHube.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp_usage">Použitie: help</system:String>

    <!-- Label appended to legacy .json import files -->
    <system:String x:Key="plugin_quickssh_import_legacy_label">(legacy)</system:String>

    <!-- LEGACY ADD REDIRECT -->
    <system:String x:Key="plugin_quickssh_title_commandadd_legacy">Command renamed: use "profiles add"</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandadd_legacy">The "add" command is now "profiles add &lt;name&gt; &lt;ssh-command&gt;". Press Enter or Tab to navigate.</system:String>

</ResourceDictionary>
