<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Plugin meta -->
    <system:String x:Key="plugin_quickssh_plugin_name">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_plugin_description">Szybko zapisuj i uruchamiaj połączenia SSH/SCP z Flow Launcher.</system:String>

    <!-- Health / status messages -->
    <system:String x:Key="plugin_quickssh_sshnotinstalled_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_sshnotinstalled_subtitle">OpenSSH client not found on this system.</system:String>

    <system:String x:Key="plugin_quickssh_databasenotcreated_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_databasenotcreated_subtitle">Profiles database could not be created.</system:String>

    <!-- Shared / common -->
    <system:String x:Key="plugin_quickssh_noprofiles">No profiles saved.</system:String>
    <system:String x:Key="plugin_quickssh_noshells">No shell profiles saved.</system:String>
    <system:String x:Key="plugin_quickssh_save_label">Save:</system:String>
    <system:String x:Key="plugin_quickssh_connect_label">Connect:</system:String>
    <system:String x:Key="plugin_quickssh_addshell_label">Add shell:</system:String>

    <!-- PROFILES (list / connect) -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles">Zarządzanie profilami</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles">Użycie: profiles add | remove | rename | copy | export | import</system:String>

    <!-- PROFILES ADD -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_add">Dodaj profil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_add">Użycie: profiles add &lt;nazwa&gt; &lt;polecenie-ssh&gt;</system:String>

    <!-- PROFILES REMOVE -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_remove">Usuń profil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_remove">Użycie: profiles remove [filtr]</system:String>

    <!-- PROFILES RENAME -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_rename">Zmień nazwę profilu</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_rename">Użycie: profiles rename &lt;stara nazwa&gt; &lt;nowa nazwa&gt;</system:String>
    <system:String x:Key="plugin_quickssh_rename_notfound">Profile not found.</system:String>

    <!-- PROFILES COPY -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_copy">Kopiuj polecenie SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy">Kopiuj:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy_usage">Użycie: profiles copy [filtr]</system:String>
    <system:String x:Key="plugin_quickssh_copy_clipboard_error">Could not copy to clipboard. Ensure Flow Launcher is running on the UI thread.</system:String>

    <!-- PROFILES EXPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_export">Eksportuj profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export">Eksportuj profile do: {0}</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export_usage">Użycie: profiles export</system:String>
    <system:String x:Key="plugin_quickssh_export_success">Exported {0} profile(s) to {1}</system:String>

    <!-- PROFILES IMPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_import">Importuj profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_import_usage">Użycie: profiles import [filtr]</system:String>
    <system:String x:Key="plugin_quickssh_import_nofiles">Brak plików .sshconfig lub .json w: {0}</system:String>
    <system:String x:Key="plugin_quickssh_import_success">Imported {0} profile(s) successfully.</system:String>
    <system:String x:Key="plugin_quickssh_import_empty">No profiles found in the selected file.</system:String>

    <!-- DIRECT CONNECT -->
    <system:String x:Key="plugin_quickssh_title_commanddirect">Direct connect</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect">Direct connect:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect_usage">Usage: ssh root@host  |  ssh -p 22 root@host  |  ssh -i "key" root@host</system:String>

    <!-- SHELL -->
    <system:String x:Key="plugin_quickssh_title_commandshell">Shell management</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_add">Add shell profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_add_usage">Usage: shell add &lt;exe&gt; or shell add &lt;name&gt; &lt;exe + args&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_remove">Remove shell profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_remove">Usage: shell remove [filter]</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_help">Usage: shell add ; remove</system:String>
    <system:String x:Key="plugin_quickssh_shell_selected">(selected)</system:String>

    <!-- CONFIG -->
    <system:String x:Key="plugin_quickssh_title_commandconfig">Import SSH config</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig">Import hosts from ~/.ssh/config file.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig_usage">Użycie: config  (importuje z ~/.ssh/config)</system:String>
    <system:String x:Key="plugin_quickssh_config_imported">Imported {0} host(s) from SSH config.</system:String>
    <system:String x:Key="plugin_quickssh_config_notfound">SSH config file not found at ~/.ssh/config.</system:String>

    <!-- HELP -->
    <system:String x:Key="plugin_quickssh_title_commandhelp">Help</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp">Open plugin documentation on GitHub.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp_usage">Usage: help</system:String>

    <!-- Label appended to legacy .json import files -->
    <system:String x:Key="plugin_quickssh_import_legacy_label">(legacy)</system:String>

    <!-- LEGACY ADD REDIRECT -->
    <system:String x:Key="plugin_quickssh_title_commandadd_legacy">Command renamed: use "profiles add"</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandadd_legacy">The "add" command is now "profiles add &lt;name&gt; &lt;ssh-command&gt;". Press Enter or Tab to navigate.</system:String>

    <!-- BACK NAVIGATION -->
    <system:String x:Key="plugin_quickssh_back_nav_title">← Wróć do {0}</system:String>

    <!-- KEYS (SSH key management) -->
    <system:String x:Key="plugin_quickssh_title_commandkeys">Zarządzanie kluczami SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys">Użycie: keys add | generate | remove | rename | copy-path | copy-pub | scan</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_add">Zarejestruj klucz SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_add">Użycie: keys add &lt;alias&gt; &lt;ścieżka-do-klucza&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_generate">Wygeneruj parę kluczy SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_generate">Użycie: keys generate &lt;alias&gt; [własna-ścieżka]</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_confirm">Wygeneruj: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_subtitle">{0} → {1} (bez hasła)</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_invalid_alias">Nieprawidłowy alias — zawiera tylko nieprawidłowe znaki.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_duplicate">Alias już istnieje: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_file_exists">Plik klucza już istnieje: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_invalid_path">Nieprawidłowa ścieżka: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_path_is_directory">Ścieżka jest katalogiem, nie plikiem klucza: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_custom_path_title">Własna ścieżka…</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_custom_path_hint">Wpisz: {0} keys generate {1} C:\ścieżka\do\klucza</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_no_keygen">ssh-keygen nie znaleziony. Zainstaluj OpenSSH aby generować klucze.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_success">Klucz SSH wygenerowany: {0}
Prywatny: {1}
Publiczny: {2}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_failed">Generowanie klucza anulowane lub nie powiodło się.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_failed_detail">Generowanie klucza nie powiodło się: {0}</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_remove">Usuń klucz SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_remove">Użycie: keys remove [filtr]</system:String>
    <system:String x:Key="plugin_quickssh_keys_remove_success">Alias klucza SSH usunięty: {0}
Usunięto tylko wpis rejestru.
Pliki zachowane na dysku: {1}</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_rename">Zmień alias klucza</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_rename">Użycie: keys rename &lt;stary-alias&gt; &lt;nowy-alias&gt;</system:String>
    <system:String x:Key="plugin_quickssh_keys_rename_notfound">Alias klucza nie znaleziony.</system:String>
    <system:String x:Key="plugin_quickssh_keys_rename_duplicate">Alias o tej nazwie już istnieje.</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_copypath">Kopiuj ścieżkę klucza</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_copypath">Użycie: keys copy-path [filtr]</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypath_label">Kopiuj ścieżkę:</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_copypub">Kopiuj klucz publiczny</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_copypub">Użycie: keys copy-pub [filtr]</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypub_label">Kopiuj .pub:</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypub_notfound">Plik klucza publicznego (.pub) nie znaleziony:</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_scan">Szukaj kluczy</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_scan">Skanuj ~/.ssh/ w poszukiwaniu plików kluczy</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_nodir">Katalog ~/.ssh/ nie znaleziony.</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_empty">Nie znaleziono plików kluczy w ~/.ssh/</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_registered">(już zarejestrowany)</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_register">Zarejestruj:</system:String>
    <system:String x:Key="plugin_quickssh_nokeys">Brak zarejestrowanych kluczy SSH.</system:String>
    <system:String x:Key="plugin_quickssh_keys_file_missing">(plik nie znaleziony)</system:String>
    <system:String x:Key="plugin_quickssh_keys_identity">Plik tożsamości:</system:String>

</ResourceDictionary>
