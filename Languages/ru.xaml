<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Plugin meta -->
    <system:String x:Key="plugin_quickssh_plugin_name">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_plugin_description">Быстро сохраняйте и запускайте SSH/SCP-соединения из Flow Launcher.</system:String>

    <!-- Health / status messages -->
    <system:String x:Key="plugin_quickssh_sshnotinstalled_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_sshnotinstalled_subtitle">OpenSSH client not found on this system.</system:String>

    <system:String x:Key="plugin_quickssh_databasenotcreated_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_databasenotcreated_subtitle">Profiles database could not be created.</system:String>

    <!-- Shared / common -->
    <system:String x:Key="plugin_quickssh_noprofiles">No profiles saved.</system:String>
    <system:String x:Key="plugin_quickssh_noshells">No shell profiles saved.</system:String>
    <system:String x:Key="plugin_quickssh_save_label">Save:</system:String>
    <system:String x:Key="plugin_quickssh_connect_label">Connect:</system:String>
    <system:String x:Key="plugin_quickssh_addshell_label">Add shell:</system:String>

    <!-- PROFILES (list / connect) -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles">Управление профилями</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles">Использование: profiles add | remove | rename | copy | export | import</system:String>

    <!-- PROFILES ADD -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_add">Добавить профиль</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_add">Использование: profiles add &lt;имя&gt; &lt;ssh-команда&gt;</system:String>

    <!-- PROFILES REMOVE -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_remove">Удалить профиль</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_remove">Использование: profiles remove [фильтр]</system:String>

    <!-- PROFILES RENAME -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_rename">Переименовать профиль</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_rename">Использование: profiles rename &lt;старое имя&gt; &lt;новое имя&gt;</system:String>
    <system:String x:Key="plugin_quickssh_rename_notfound">Profile not found.</system:String>

    <!-- PROFILES COPY -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_copy">Скопировать SSH-команду</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy">Копировать:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy_usage">Использование: profiles copy [фильтр]</system:String>
    <system:String x:Key="plugin_quickssh_copy_clipboard_error">Could not copy to clipboard. Ensure Flow Launcher is running on the UI thread.</system:String>
    <system:String x:Key="plugin_quickssh_copy_command_success">Команда SSH скопирована в буфер обмена.</system:String>
    <system:String x:Key="plugin_quickssh_copy_keypath_success">Путь к ключу скопирован в буфер обмена.</system:String>
    <system:String x:Key="plugin_quickssh_copy_pubkey_success">Открытый ключ скопирован в буфер обмена.</system:String>

    <!-- PROFILES EXPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_export">Экспорт профилей</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export">Экспортировать профили в: {0}</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export_usage">Использование: profiles export</system:String>
    <system:String x:Key="plugin_quickssh_export_success">Exported {0} profile(s) to {1}</system:String>

    <!-- PROFILES IMPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_import">Импорт профилей</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_import_usage">Использование: profiles import [фильтр]</system:String>
    <system:String x:Key="plugin_quickssh_import_nofiles">Файлы .sshconfig или .json не найдены в: {0}</system:String>
    <system:String x:Key="plugin_quickssh_import_success">Imported {0} profile(s) successfully.</system:String>
    <system:String x:Key="plugin_quickssh_import_empty">No profiles found in the selected file.</system:String>

    <!-- DIRECT CONNECT -->
    <system:String x:Key="plugin_quickssh_title_commanddirect">Direct connect</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect">Direct connect:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect_usage">Usage: ssh root@host  |  ssh -p 22 root@host  |  ssh -i "key" root@host</system:String>

    <!-- SHELL -->
    <system:String x:Key="plugin_quickssh_title_commandshell">Shell management</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_add">Add shell profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_add_usage">Usage: shell add &lt;exe&gt; or shell add &lt;name&gt; &lt;exe + args&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_remove">Remove shell profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_remove">Usage: shell remove [filter]</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_help">Usage: shell add ; remove</system:String>
    <system:String x:Key="plugin_quickssh_shell_selected">(selected)</system:String>

    <!-- CONFIG -->
    <system:String x:Key="plugin_quickssh_title_commandconfig">Import SSH config</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig">Import hosts from ~/.ssh/config file.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig_usage">Использование: config  (импорт из ~/.ssh/config)</system:String>
    <system:String x:Key="plugin_quickssh_config_imported">Imported {0} host(s) from SSH config.</system:String>
    <system:String x:Key="plugin_quickssh_config_notfound">SSH config file not found at ~/.ssh/config.</system:String>

    <!-- HELP -->
    <system:String x:Key="plugin_quickssh_title_commandhelp">Help</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp">Open plugin documentation on GitHub.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp_usage">Usage: help</system:String>

    <!-- Label appended to legacy .json import files -->
    <system:String x:Key="plugin_quickssh_import_legacy_label">(legacy)</system:String>

    <!-- LEGACY ADD REDIRECT -->
    <system:String x:Key="plugin_quickssh_title_commandadd_legacy">Command renamed: use "profiles add"</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandadd_legacy">The "add" command is now "profiles add &lt;name&gt; &lt;ssh-command&gt;". Press Enter or Tab to navigate.</system:String>

    <!-- BACK NAVIGATION -->
    <system:String x:Key="plugin_quickssh_back_nav_title">← Назад к {0}</system:String>

    <!-- KEYS (SSH key management) -->
    <system:String x:Key="plugin_quickssh_title_commandkeys">Управление SSH-ключами</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys">Использование: keys install | add | generate | remove | rename | copy-path | copy-pub | scan</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_add">Зарегистрировать SSH-ключ</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_add">Использование: keys add &lt;псевдоним&gt; &lt;путь-к-ключу&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_generate">Сгенерировать пару SSH-ключей</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_generate">Использование: keys generate &lt;псевдоним&gt; [свой-путь]</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_confirm">Сгенерировать: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_subtitle">{0} → {1} (без пароля)</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_invalid_alias">Недопустимый псевдоним — содержит только недопустимые символы.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_duplicate">Псевдоним уже существует: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_file_exists">Файл ключа уже существует: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_invalid_path">Недопустимый путь: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_path_is_directory">Путь является каталогом, а не файлом ключа: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_custom_path_title">Свой путь…</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_custom_path_hint">Введите: {0} keys generate {1} C:\путь\к\ключу</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_no_keygen">ssh-keygen не найден. Установите OpenSSH для генерации ключей.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_success">SSH-ключ сгенерирован: {0}
Приватный: {1}
Публичный: {2}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_failed">Генерация ключа отменена или не удалась.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_failed_detail">Ошибка генерации ключа: {0}</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_remove">Удалить SSH-ключ</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_remove">Использование: keys remove [фильтр]</system:String>
    <system:String x:Key="plugin_quickssh_keys_remove_success">Псевдоним SSH-ключа удалён: {0}
Удалена только запись в реестре.
Файлы на диске сохранены: {1}</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_rename">Переименовать псевдоним ключа</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_rename">Использование: keys rename &lt;старый-псевдоним&gt; &lt;новый-псевдоним&gt;</system:String>
    <system:String x:Key="plugin_quickssh_keys_rename_notfound">Псевдоним ключа не найден.</system:String>
    <system:String x:Key="plugin_quickssh_keys_rename_duplicate">Псевдоним с таким именем уже существует.</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_copypath">Копировать путь к ключу</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_copypath">Использование: keys copy-path [фильтр]</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypath_label">Копировать путь:</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_copypub">Копировать открытый ключ</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_copypub">Использование: keys copy-pub [фильтр]</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypub_label">Копировать .pub:</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypub_notfound">Файл открытого ключа (.pub) не найден:</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_scan">Найти ключи</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_scan">Сканировать ~/.ssh/ на файлы ключей</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_nodir">Каталог ~/.ssh/ не найден.</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_empty">Файлы ключей в ~/.ssh/ не найдены</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_registered">(уже зарегистрирован)</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_register">Зарегистрировать:</system:String>
    <system:String x:Key="plugin_quickssh_nokeys">Нет зарегистрированных SSH-ключей.</system:String>
    <system:String x:Key="plugin_quickssh_keys_file_missing">(файл не найден)</system:String>
    <system:String x:Key="plugin_quickssh_keys_identity">Файл идентификации:</system:String>

</ResourceDictionary>
