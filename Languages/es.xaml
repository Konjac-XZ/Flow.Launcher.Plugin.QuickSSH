<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Plugin meta -->
    <system:String x:Key="plugin_quickssh_plugin_name">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_plugin_description">Guarda y lanza rápidamente conexiones SSH/SCP desde Flow Launcher.</system:String>

    <!-- Health / status messages -->
    <system:String x:Key="plugin_quickssh_sshnotinstalled_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_sshnotinstalled_subtitle">OpenSSH client not found on this system.</system:String>

    <system:String x:Key="plugin_quickssh_databasenotcreated_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_databasenotcreated_subtitle">Profiles database could not be created.</system:String>

    <!-- Shared / common -->
    <system:String x:Key="plugin_quickssh_noprofiles">No profiles saved.</system:String>
    <system:String x:Key="plugin_quickssh_noshells">No shell profiles saved.</system:String>
    <system:String x:Key="plugin_quickssh_save_label">Save:</system:String>
    <system:String x:Key="plugin_quickssh_connect_label">Connect:</system:String>
    <system:String x:Key="plugin_quickssh_addshell_label">Add shell:</system:String>

    <!-- PROFILES (list / connect) -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles">Gestión de perfiles</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles">Uso: profiles add | remove | rename | copy | export | import</system:String>

    <!-- PROFILES ADD -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_add">Añadir perfil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_add">Uso: profiles add &lt;nombre&gt; &lt;comando-ssh&gt;</system:String>

    <!-- PROFILES REMOVE -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_remove">Eliminar perfil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_remove">Uso: profiles remove [filtro]</system:String>

    <!-- PROFILES RENAME -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_rename">Renombrar perfil</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_rename">Uso: profiles rename &lt;nombre antiguo&gt; &lt;nombre nuevo&gt;</system:String>
    <system:String x:Key="plugin_quickssh_rename_notfound">Profile not found.</system:String>

    <!-- PROFILES COPY -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_copy">Copiar comando SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy">Copiar:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy_usage">Uso: profiles copy [filtro]</system:String>
    <system:String x:Key="plugin_quickssh_copy_clipboard_error">Could not copy to clipboard. Ensure Flow Launcher is running on the UI thread.</system:String>

    <!-- PROFILES EXPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_export">Exportar perfiles</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export">Exportar perfiles a: {0}</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export_usage">Uso: profiles export</system:String>
    <system:String x:Key="plugin_quickssh_export_success">Exported {0} profile(s) to {1}</system:String>

    <!-- PROFILES IMPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_import">Importar perfiles</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_import_usage">Uso: profiles import [filtro]</system:String>
    <system:String x:Key="plugin_quickssh_import_nofiles">No se encontraron archivos .sshconfig o .json en: {0}</system:String>
    <system:String x:Key="plugin_quickssh_import_success">Imported {0} profile(s) successfully.</system:String>
    <system:String x:Key="plugin_quickssh_import_empty">No profiles found in the selected file.</system:String>

    <!-- DIRECT CONNECT -->
    <system:String x:Key="plugin_quickssh_title_commanddirect">Direct connect</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect">Direct connect:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect_usage">Usage: ssh root@host  |  ssh -p 22 root@host  |  ssh -i "key" root@host</system:String>

    <!-- SHELL -->
    <system:String x:Key="plugin_quickssh_title_commandshell">Shell management</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_add">Add shell profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_add_usage">Usage: shell add &lt;exe&gt; or shell add &lt;name&gt; &lt;exe + args&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_remove">Remove shell profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_remove">Usage: shell remove [filter]</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_help">Usage: shell add ; remove</system:String>
    <system:String x:Key="plugin_quickssh_shell_selected">(selected)</system:String>

    <!-- CONFIG -->
    <system:String x:Key="plugin_quickssh_title_commandconfig">Import SSH config</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig">Import hosts from ~/.ssh/config file.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig_usage">Uso: config  (importa desde ~/.ssh/config)</system:String>
    <system:String x:Key="plugin_quickssh_config_imported">Imported {0} host(s) from SSH config.</system:String>
    <system:String x:Key="plugin_quickssh_config_notfound">SSH config file not found at ~/.ssh/config.</system:String>

    <!-- HELP -->
    <system:String x:Key="plugin_quickssh_title_commandhelp">Help</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp">Open plugin documentation on GitHub.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp_usage">Usage: help</system:String>

    <!-- Label appended to legacy .json import files -->
    <system:String x:Key="plugin_quickssh_import_legacy_label">(legacy)</system:String>

    <!-- LEGACY ADD REDIRECT -->
    <system:String x:Key="plugin_quickssh_title_commandadd_legacy">Command renamed: use "profiles add"</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandadd_legacy">The "add" command is now "profiles add &lt;name&gt; &lt;ssh-command&gt;". Press Enter or Tab to navigate.</system:String>

    <!-- BACK NAVIGATION -->
    <system:String x:Key="plugin_quickssh_back_nav_title">← Volver a {0}</system:String>

    <!-- KEYS (SSH key management) -->
    <system:String x:Key="plugin_quickssh_title_commandkeys">Gestión de claves SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys">Uso: keys add | generate | remove | rename | copy-path | copy-pub | scan</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_add">Registrar clave SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_add">Uso: keys add &lt;alias&gt; &lt;ruta-a-la-clave&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_generate">Generar par de claves SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_generate">Uso: keys generate &lt;alias&gt; [ruta-personalizada]</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_confirm">Generar: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_subtitle">{0} → {1} (sin contraseña)</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_invalid_alias">Alias no válido — contiene solo caracteres no válidos.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_duplicate">El alias ya existe: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_file_exists">El archivo de clave ya existe: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_invalid_path">Ruta no válida: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_path_is_directory">La ruta es un directorio, no un archivo de clave: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_custom_path_title">Ruta personalizada…</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_custom_path_hint">Escriba: {0} keys generate {1} C:\ruta\a\la\clave</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_no_keygen">ssh-keygen no encontrado. Instale OpenSSH para generar claves.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_success">Clave '{0}' generada y registrada con éxito.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_failed">Generación de clave cancelada o fallida.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_failed_detail">Fallo en la generación de clave: {0}</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_remove">Eliminar clave SSH</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_remove">Uso: keys remove [filtro]</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_rename">Renombrar alias de clave</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_rename">Uso: keys rename &lt;alias-antiguo&gt; &lt;alias-nuevo&gt;</system:String>
    <system:String x:Key="plugin_quickssh_keys_rename_notfound">Alias de clave no encontrado.</system:String>
    <system:String x:Key="plugin_quickssh_keys_rename_duplicate">Ya existe un alias con este nombre.</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_copypath">Copiar ruta de clave</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_copypath">Uso: keys copy-path [filtro]</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypath_label">Copiar ruta:</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_copypub">Copiar clave pública</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_copypub">Uso: keys copy-pub [filtro]</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypub_label">Copiar .pub:</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypub_notfound">Archivo de clave pública (.pub) no encontrado:</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_scan">Buscar claves</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_scan">Escanear ~/.ssh/ en busca de archivos de claves</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_nodir">Directorio ~/.ssh/ no encontrado.</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_empty">No se encontraron archivos de claves en ~/.ssh/</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_registered">(ya registrado)</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_register">Registrar:</system:String>
    <system:String x:Key="plugin_quickssh_nokeys">No hay claves SSH registradas.</system:String>
    <system:String x:Key="plugin_quickssh_keys_file_missing">(archivo no encontrado)</system:String>
    <system:String x:Key="plugin_quickssh_keys_identity">Archivo de identidad:</system:String>

</ResourceDictionary>
