<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Plugin meta -->
    <system:String x:Key="plugin_quickssh_plugin_name">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_plugin_description">SSH-Verbindungen in Flow Launcher schnell speichern und starten.</system:String>

    <!-- Health / status messages -->
    <system:String x:Key="plugin_quickssh_sshnotinstalled_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_sshnotinstalled_subtitle">OpenSSH-Client auf diesem System nicht gefunden.</system:String>

    <system:String x:Key="plugin_quickssh_databasenotcreated_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_databasenotcreated_subtitle">Profildatenbank konnte nicht erstellt werden.</system:String>

    <!-- Shared / common -->
    <system:String x:Key="plugin_quickssh_noprofiles">Keine Profile gespeichert.</system:String>
    <system:String x:Key="plugin_quickssh_noshells">Keine Shell-Profile gespeichert.</system:String>
    <system:String x:Key="plugin_quickssh_save_label">Speichern:</system:String>
    <system:String x:Key="plugin_quickssh_connect_label">Verbinden:</system:String>
    <system:String x:Key="plugin_quickssh_addshell_label">Shell hinzufügen:</system:String>

    <!-- ADD -->
    <system:String x:Key="plugin_quickssh_title_commandadd">Profil hinzufügen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandadd">Verwendung: add &lt;Name&gt; &lt;SSH-Befehl&gt;</system:String>

    <!-- REMOVE -->
    <system:String x:Key="plugin_quickssh_title_commandremove">Profil entfernen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandremove">Verwendung: remove [Filter]</system:String>

    <!-- PROFILES -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles">Gespeicherte Profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles">Verwendung: profiles [Filter]</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandp_usage">Verwendung: p [Filter]</system:String>

    <!-- DIRECT CONNECT -->
    <system:String x:Key="plugin_quickssh_title_commanddirect">Direkte Verbindung</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect">Direkte Verbindung:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandd_usage">Verwendung: d &lt;SSH-Befehl&gt;</system:String>

    <!-- SHELL -->
    <system:String x:Key="plugin_quickssh_title_commandshell">Shell-Verwaltung</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_add">Shell-Profil hinzufügen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_add_usage">Verwendung: shell add &lt;exe&gt; oder shell add &lt;Name&gt; &lt;exe + Argumente&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_remove">Shell-Profil entfernen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_remove">Verwendung: shell remove [Filter]</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_help">Verwendung: shell add ; remove ; list</system:String>
    <system:String x:Key="plugin_quickssh_shell_selected">(ausgewählt)</system:String>

    <!-- CONFIG -->
    <system:String x:Key="plugin_quickssh_title_commandconfig">SSH-Konfiguration importieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig">Hosts aus ~/.ssh/config-Datei importieren.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig_usage">Verwendung: config</system:String>
    <system:String x:Key="plugin_quickssh_config_imported">{0} Host(s) aus SSH-Konfiguration importiert.</system:String>
    <system:String x:Key="plugin_quickssh_config_notfound">SSH-Konfigurationsdatei nicht unter ~/.ssh/config gefunden.</system:String>

    <!-- EXPORT -->
    <system:String x:Key="plugin_quickssh_title_commandexport">Profile exportieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandexport">SSH-Profile exportieren nach: {0}</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandexport_usage">Verwendung: export</system:String>
    <system:String x:Key="plugin_quickssh_export_success">{0} Profil(e) nach {1} exportiert</system:String>

    <!-- IMPORT -->
    <system:String x:Key="plugin_quickssh_title_commandimport">Profile importieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandimport_usage">Verwendung: import [Filter]</system:String>
    <system:String x:Key="plugin_quickssh_import_nofiles">Keine JSON-Dateien gefunden in: {0}</system:String>
    <system:String x:Key="plugin_quickssh_import_success">{0} Profil(e) erfolgreich importiert.</system:String>
    <system:String x:Key="plugin_quickssh_import_empty">Keine Profile in der ausgewählten Datei gefunden.</system:String>

    <!-- COPY -->
    <system:String x:Key="plugin_quickssh_title_commandcopy">SSH-Befehl kopieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandcopy">Kopieren:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandcopy_usage">Verwendung: copy &lt;Vorhandener&gt; &lt;neuer-Name&gt;</system:String>
    <system:String x:Key="plugin_quickssh_copy_clipboard_error">Kopieren in die Zwischenablage fehlgeschlagen. Stellen Sie sicher, dass Flow Launcher auf dem UI-Thread läuft.</system:String>

    <!-- RENAME -->
    <system:String x:Key="plugin_quickssh_title_commandrename">Profil umbenennen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandrename">Verwendung: rename &lt;Alter Name&gt; &lt;Neuer Name&gt;</system:String>
    <system:String x:Key="plugin_quickssh_rename_notfound">Profil nicht gefunden.</system:String>

    <!-- DOCS -->
    <system:String x:Key="plugin_quickssh_title_commanddocs">Dokumentation</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddocs">Plugin-Dokumentation auf GitHub öffnen.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddocs_usage">Verwendung: docs</system:String>

</ResourceDictionary>
