<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Plugin meta -->
    <system:String x:Key="plugin_quickssh_plugin_name">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_plugin_description">SSH/SCP-Verbindungen in Flow Launcher schnell speichern und starten.</system:String>

    <!-- Health / status messages -->
    <system:String x:Key="plugin_quickssh_sshnotinstalled_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_sshnotinstalled_subtitle">OpenSSH-Client auf diesem System nicht gefunden.</system:String>

    <system:String x:Key="plugin_quickssh_databasenotcreated_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_databasenotcreated_subtitle">Profildatenbank konnte nicht erstellt werden.</system:String>

    <!-- Shared / common -->
    <system:String x:Key="plugin_quickssh_noprofiles">Keine Profile gespeichert.</system:String>
    <system:String x:Key="plugin_quickssh_noshells">Keine Shell-Profile gespeichert.</system:String>
    <system:String x:Key="plugin_quickssh_save_label">Speichern:</system:String>
    <system:String x:Key="plugin_quickssh_connect_label">Verbinden:</system:String>
    <system:String x:Key="plugin_quickssh_addshell_label">Shell hinzufügen:</system:String>

    <!-- PROFILES (list / connect) -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles">Profilverwaltung</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles">Verwendung: profiles add | remove | rename | copy | export | import</system:String>

    <!-- PROFILES ADD -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_add">Profil hinzufügen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_add">Verwendung: profiles add &lt;Name&gt; &lt;SSH-Befehl&gt;</system:String>

    <!-- PROFILES REMOVE -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_remove">Profil entfernen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_remove">Verwendung: profiles remove [Filter]</system:String>

    <!-- PROFILES RENAME -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_rename">Profil umbenennen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_rename">Verwendung: profiles rename &lt;Alter Name&gt; &lt;Neuer Name&gt;</system:String>
    <system:String x:Key="plugin_quickssh_rename_notfound">Profil nicht gefunden.</system:String>

    <!-- PROFILES COPY -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_copy">SSH-Befehl kopieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy">Kopieren:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy_usage">Verwendung: profiles copy [Filter]</system:String>
    <system:String x:Key="plugin_quickssh_copy_clipboard_error">Kopieren in die Zwischenablage fehlgeschlagen. Stellen Sie sicher, dass Flow Launcher auf dem UI-Thread läuft.</system:String>

    <!-- PROFILES EXPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_export">Profile exportieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export">Profile exportieren nach: {0}</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export_usage">Verwendung: profiles export</system:String>
    <system:String x:Key="plugin_quickssh_export_success">{0} Profil(e) nach {1} exportiert</system:String>

    <!-- PROFILES IMPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_import">Profile importieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_import_usage">Verwendung: profiles import [Filter]</system:String>
    <system:String x:Key="plugin_quickssh_import_nofiles">Keine .sshconfig- oder .json-Dateien gefunden in: {0}</system:String>
    <system:String x:Key="plugin_quickssh_import_success">{0} Profil(e) erfolgreich importiert.</system:String>
    <system:String x:Key="plugin_quickssh_import_empty">Keine Profile in der ausgewählten Datei gefunden.</system:String>

    <!-- DIRECT CONNECT -->
    <system:String x:Key="plugin_quickssh_title_commanddirect">Direkte Verbindung</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect">Direkte Verbindung:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect_usage">Verwendung: ssh root@host  |  ssh -p 22 root@host  |  ssh -i "key" root@host</system:String>

    <!-- SHELL -->
    <system:String x:Key="plugin_quickssh_title_commandshell">Shell-Verwaltung</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_add">Shell-Profil hinzufügen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_add_usage">Verwendung: shell add &lt;exe&gt; oder shell add &lt;Name&gt; &lt;exe + Argumente&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_remove">Shell-Profil entfernen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_remove">Verwendung: shell remove [Filter]</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_help">Verwendung: shell add ; remove</system:String>
    <system:String x:Key="plugin_quickssh_shell_selected">(ausgewählt)</system:String>

    <!-- CONFIG -->
    <system:String x:Key="plugin_quickssh_title_commandconfig">SSH-Konfiguration importieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig">Hosts aus ~/.ssh/config-Datei importieren.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig_usage">Verwendung: config  (importiert aus ~/.ssh/config)</system:String>
    <system:String x:Key="plugin_quickssh_config_imported">{0} Host(s) aus SSH-Konfiguration importiert.</system:String>
    <system:String x:Key="plugin_quickssh_config_notfound">SSH-Konfigurationsdatei nicht unter ~/.ssh/config gefunden.</system:String>

    <!-- HELP -->
    <system:String x:Key="plugin_quickssh_title_commandhelp">Hilfe</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp">Plugin-Dokumentation auf GitHub öffnen.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp_usage">Verwendung: help</system:String>

    <!-- Label appended to legacy .json import files -->
    <system:String x:Key="plugin_quickssh_import_legacy_label">(legacy)</system:String>

    <!-- LEGACY ADD REDIRECT -->
    <system:String x:Key="plugin_quickssh_title_commandadd_legacy">Command renamed: use "profiles add"</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandadd_legacy">The "add" command is now "profiles add &lt;name&gt; &lt;ssh-command&gt;". Press Enter or Tab to navigate.</system:String>

    <!-- BACK NAVIGATION -->
    <system:String x:Key="plugin_quickssh_back_nav_title">← Zurück zu {0}</system:String>

    <!-- KEYS (SSH key management) -->
    <system:String x:Key="plugin_quickssh_title_commandkeys">SSH-Schlüsselverwaltung</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys">Verwendung: keys add | remove</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_add">SSH-Schlüssel registrieren</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_add">Verwendung: keys add &lt;Alias&gt; &lt;Pfad-zum-Schlüssel&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_remove">SSH-Schlüssel entfernen</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_remove">Verwendung: keys remove [Filter]</system:String>
    <system:String x:Key="plugin_quickssh_nokeys">Keine SSH-Schlüssel registriert.</system:String>
    <system:String x:Key="plugin_quickssh_keys_file_missing">(Datei nicht gefunden)</system:String>
    <system:String x:Key="plugin_quickssh_keys_identity">Identitätsdatei:</system:String>

</ResourceDictionary>
