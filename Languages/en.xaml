<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Plugin meta -->
    <system:String x:Key="plugin_quickssh_plugin_name">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_plugin_description">Quickly save and launch SSH/SCP connections from Flow Launcher.</system:String>

    <!-- Health / status messages -->
    <system:String x:Key="plugin_quickssh_sshnotinstalled_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_sshnotinstalled_subtitle">OpenSSH client not found on this system.</system:String>

    <system:String x:Key="plugin_quickssh_databasenotcreated_title">QuickSSH</system:String>
    <system:String x:Key="plugin_quickssh_databasenotcreated_subtitle">Profiles database could not be created.</system:String>

    <!-- Shared / common -->
    <system:String x:Key="plugin_quickssh_noprofiles">No profiles saved.</system:String>
    <system:String x:Key="plugin_quickssh_noshells">No shell profiles saved.</system:String>
    <system:String x:Key="plugin_quickssh_save_label">Save:</system:String>
    <system:String x:Key="plugin_quickssh_connect_label">Connect:</system:String>
    <system:String x:Key="plugin_quickssh_addshell_label">Add shell:</system:String>

    <!-- PROFILES (list / connect) -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles">Profile management</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles">Usage: profiles add | remove | rename | copy | export | import</system:String>

    <!-- PROFILES ADD -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_add">Add profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_add">Usage: profiles add &lt;name&gt; &lt;ssh-command&gt;</system:String>

    <!-- PROFILES REMOVE -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_remove">Remove profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_remove">Usage: profiles remove [filter]</system:String>

    <!-- PROFILES RENAME -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_rename">Rename profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_rename">Usage: profiles rename &lt;oldname&gt; &lt;newname&gt;</system:String>
    <system:String x:Key="plugin_quickssh_rename_notfound">Profile not found.</system:String>

    <!-- PROFILES COPY -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_copy">Copy SSH command</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy">Copy:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_copy_usage">Usage: profiles copy [filter]</system:String>
    <system:String x:Key="plugin_quickssh_copy_clipboard_error">Could not copy to clipboard. Ensure Flow Launcher is running on the UI thread.</system:String>

    <!-- PROFILES EXPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_export">Export profiles</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export">Export profiles to: {0}</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_export_usage">Usage: profiles export</system:String>
    <system:String x:Key="plugin_quickssh_export_success">Exported {0} profile(s) to {1}</system:String>

    <!-- PROFILES IMPORT -->
    <system:String x:Key="plugin_quickssh_title_commandprofiles_import">Import profiles</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandprofiles_import_usage">Usage: profiles import [filter]</system:String>
    <system:String x:Key="plugin_quickssh_import_nofiles">No .sshconfig or .json files found in: {0}</system:String>
    <system:String x:Key="plugin_quickssh_import_success">Imported {0} profile(s) successfully.</system:String>
    <system:String x:Key="plugin_quickssh_import_empty">No profiles found in the selected file.</system:String>
    <!-- Label appended to legacy .json import files so users understand JSON is migration-only -->
    <system:String x:Key="plugin_quickssh_import_legacy_label">(legacy)</system:String>

    <!-- LEGACY ADD REDIRECT -->
    <!-- The top-level "add" command was removed in v2. This entry is shown when the user types "add ..." -->
    <system:String x:Key="plugin_quickssh_title_commandadd_legacy">Command renamed: use "profiles add"</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandadd_legacy">The "add" command is now "profiles add &lt;name&gt; &lt;ssh-command&gt;". Press Enter or Tab to navigate.</system:String>

    <!-- DIRECT CONNECT -->
    <system:String x:Key="plugin_quickssh_title_commanddirect">Direct connect</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect">Direct connect:</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commanddirectconnect_usage">Usage: ssh root@host  |  ssh -p 22 root@host  |  ssh -i "key" root@host</system:String>

    <!-- SHELL -->
    <system:String x:Key="plugin_quickssh_title_commandshell">Shell management</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_add">Add shell profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_add_usage">Usage: shell add &lt;exe&gt; or shell add &lt;name&gt; &lt;exe + args&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandshell_remove">Remove shell profile</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_remove">Usage: shell remove [filter]</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandshell_help">Usage: shell add ; remove</system:String>
    <system:String x:Key="plugin_quickssh_shell_selected">(selected)</system:String>

    <!-- CONFIG -->
    <system:String x:Key="plugin_quickssh_title_commandconfig">Import SSH config</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig">Import hosts from ~/.ssh/config file.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandconfig_usage">Usage: config  (imports from ~/.ssh/config)</system:String>
    <system:String x:Key="plugin_quickssh_config_imported">Imported {0} host(s) from SSH config.</system:String>
    <system:String x:Key="plugin_quickssh_config_notfound">SSH config file not found at ~/.ssh/config.</system:String>

    <!-- HELP -->
    <system:String x:Key="plugin_quickssh_title_commandhelp">Help</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp">Open plugin documentation on GitHub.</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandhelp_usage">Usage: help</system:String>

    <!-- BACK NAVIGATION -->
    <system:String x:Key="plugin_quickssh_back_nav_title">← Back to {0}</system:String>

    <!-- KEYS (SSH key management) -->
    <system:String x:Key="plugin_quickssh_title_commandkeys">SSH key management</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys">Usage: keys add | generate | remove | rename | copy-path | copy-pub | scan</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_add">Register SSH key</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_add">Usage: keys add &lt;alias&gt; &lt;path-to-key&gt;</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_generate">Generate SSH keypair</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_generate">Usage: keys generate &lt;alias&gt; [ed25519|rsa] [path]</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_confirm">Generate: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_subtitle">{0} → {1} (passphrase prompt in terminal)</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_invalid_alias">Invalid alias — contains only invalid characters.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_duplicate">Alias already exists: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_file_exists">Key file already exists: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_invalid_path">Invalid path: {0}</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_no_keygen">ssh-keygen not found. Install OpenSSH to generate keys.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_success">Key '{0}' generated and registered successfully.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_failed">Key generation cancelled or failed.</system:String>
    <system:String x:Key="plugin_quickssh_keys_generate_failed_detail">Key generation failed: {0}</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_remove">Remove SSH key</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_remove">Usage: keys remove [filter]</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_rename">Rename SSH key alias</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_rename">Usage: keys rename &lt;old-alias&gt; &lt;new-alias&gt;</system:String>
    <system:String x:Key="plugin_quickssh_keys_rename_notfound">Key alias not found.</system:String>
    <system:String x:Key="plugin_quickssh_keys_rename_duplicate">An alias with this name already exists.</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_copypath">Copy key path</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_copypath">Usage: keys copy-path [filter]</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypath_label">Copy path:</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_copypub">Copy public key</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_copypub">Usage: keys copy-pub [filter]</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypub_label">Copy .pub:</system:String>
    <system:String x:Key="plugin_quickssh_keys_copypub_notfound">Public key file (.pub) not found:</system:String>
    <system:String x:Key="plugin_quickssh_title_commandkeys_scan">Scan for keys</system:String>
    <system:String x:Key="plugin_quickssh_subtitle_commandkeys_scan">Scan ~/.ssh/ for key files to register</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_nodir">~/.ssh/ directory not found.</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_empty">No key files found in ~/.ssh/</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_registered">(already registered)</system:String>
    <system:String x:Key="plugin_quickssh_keys_scan_register">Register:</system:String>
    <system:String x:Key="plugin_quickssh_nokeys">No SSH keys registered.</system:String>
    <system:String x:Key="plugin_quickssh_keys_file_missing">(file not found)</system:String>
    <system:String x:Key="plugin_quickssh_keys_identity">Identity file:</system:String>

</ResourceDictionary>
